package analysis.calcs;

import deal.std.units.{Force, Pressure, Density, Speed, Area, Mass, Energy, percent, N};
import analysis.constraints.{PositiveForce};

/** Pure function — composable inside any expression. */
calc def MarginOfSafety(allowable : Pressure, actual : Pressure) : Real {
    return allowable / actual - 1;
}

/** Calc with a return contract (SD-23): precision + a named predicate, list form. */
